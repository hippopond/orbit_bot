    <?xml version="1.0"?>                                                                                          
    <robot name="orbit_bot">                                                                                       
      <link name="base_link">                                                                                      
        <visual>                                                                                                   
          <geometry>                                                                                               
            <!-- A simple rectangular box -->                                                                      
            <box size="0.5 0.3 0.2"/>                                                                              
          </geometry>                                                                                              
          <material name="orange">                                                                                 
            <color rgba="1.0 0.5 0.0 1.0"/>                                                                        
          </material>                                                                                              
        </visual>                                                                                                  
      </link>                                                                                                      
    </robot>                                                                                                       
                                                                                                                   
